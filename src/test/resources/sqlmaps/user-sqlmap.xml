<sqlMap namespace="user">
	<select id="findUsers" parameterClass="map" resultClass="user">
		SELECT id, name
		FROM users
		<dynamic prepend="WHERE">
			<isNotEmpty property="name">
				AND name = #name#
			</isNotEmpty>
			<isNotEmpty property="status">
				AND status = #status#
			</isNotEmpty>
			<isNotEmpty property="ids">
				AND id IN
				<iterate property="ids" open="(" close=")" conjunction=",">
					#ids[]#
				</iterate>
			</isNotEmpty>
		</dynamic>
	</select>
</sqlMap>
